<UserControl x:Class="IntuneWinPackager.Views.PackagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:vm="clr-namespace:IntuneWinPackager.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:PackagerViewModel}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <local:InverseBoolConverter x:Key="InverseBoolConverter"
                                    xmlns:local="clr-namespace:IntuneWinPackager.Views" />
        <local:StringNotEmptyToVisibilityConverter x:Key="StringToVisibilityConverter"
                                                    xmlns:local="clr-namespace:IntuneWinPackager.Views" />
    </UserControl.Resources>

    <Grid Margin="24,16,24,24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="24" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ═══════════ LEFT COLUMN ═══════════ -->
        <StackPanel Grid.Column="0">

            <!-- ═══ Win32 Content Prep Tool Path ═══ -->
            <TextBlock Text="Win32 Content Prep Tool" FontWeight="SemiBold" Margin="0,0,0,8" />
            <ui:CardControl>
                <ui:CardControl.Header>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:TextBox Grid.Column="0"
                                    Text="{Binding ExePath, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="Path to IntuneWinAppUtil.exe" />
                        <ui:Button Grid.Column="1" Content="Browse" Margin="8,0,0,0"
                                   Click="BrowseExe_Click" />
                    </Grid>
                </ui:CardControl.Header>
            </ui:CardControl>
            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                <ui:Button Content="Download Latest"
                           Command="{Binding DownloadToolCommand}"
                           IsEnabled="{Binding IsDownloading, Converter={StaticResource InverseBoolConverter}}"
                           Padding="8,4"
                           Margin="0,0,8,0" />
                <ui:HyperlinkButton Content="View on GitHub"
                                    NavigateUri="https://github.com/microsoft/Microsoft-Win32-Content-Prep-Tool"
                                    Padding="0,4"
                                    VerticalAlignment="Center"
                                    Click="DownloadLink_Click" />
            </StackPanel>

            <!-- ═══ Package Settings ═══ -->
            <TextBlock Text="Package Settings" FontWeight="SemiBold" Margin="0,20,0,8" />

            <!-- Source Folder -->
            <ui:CardControl Margin="0,0,0,4">
                <ui:CardControl.Header>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Source Folder" VerticalAlignment="Center" />
                        <ComboBox Grid.Column="1"
                                  Text="{Binding SourceFolder, UpdateSourceTrigger=PropertyChanged}"
                                  ItemsSource="{Binding RecentSourceFolders}"
                                  IsEditable="True"
                                  AllowDrop="True"
                                  PreviewDragOver="Folder_DragOver"
                                  Drop="SourceFolder_Drop" />
                        <ui:Button Grid.Column="2" Content="Browse" Margin="8,0,0,0"
                                   Click="BrowseSource_Click" />
                    </Grid>
                </ui:CardControl.Header>
            </ui:CardControl>

            <!-- Setup File -->
            <ui:CardControl Margin="0,0,0,4">
                <ui:CardControl.Header>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Setup File" VerticalAlignment="Center" />
                        <ui:TextBox Grid.Column="1"
                                    Text="{Binding SetupFile, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="Main installer (e.g., setup.exe)"
                                    AllowDrop="True"
                                    PreviewDragOver="File_DragOver"
                                    Drop="SetupFile_Drop" />
                        <ui:Button Grid.Column="2" Content="Browse" Margin="8,0,0,0"
                                   Click="BrowseSetup_Click" />
                    </Grid>
                </ui:CardControl.Header>
            </ui:CardControl>

            <TextBlock Text="{Binding SetupFileWarning}"
                       Foreground="Orange"
                       FontSize="12"
                       TextWrapping="Wrap"
                       Margin="4,2,0,4"
                       Visibility="{Binding SetupFileWarning, Converter={StaticResource StringToVisibilityConverter}}" />

            <!-- Output Folder -->
            <ui:CardControl Margin="0,0,0,4">
                <ui:CardControl.Header>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Output Folder" VerticalAlignment="Center" />
                        <ComboBox Grid.Column="1"
                                  Text="{Binding OutputFolder, UpdateSourceTrigger=PropertyChanged}"
                                  ItemsSource="{Binding RecentOutputFolders}"
                                  IsEditable="True"
                                  AllowDrop="True"
                                  PreviewDragOver="Folder_DragOver"
                                  Drop="OutputFolder_Drop" />
                        <ui:Button Grid.Column="2" Content="Browse" Margin="8,0,0,0"
                                   Click="BrowseOutput_Click" />
                    </Grid>
                </ui:CardControl.Header>
            </ui:CardControl>

            <!-- Catalog Folder (optional) -->
            <ui:CardControl Margin="0,0,0,4">
                <ui:CardControl.Header>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Catalog (opt.)" VerticalAlignment="Center" />
                        <ui:TextBox Grid.Column="1"
                                    Text="{Binding CatalogFolder, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="Catalog folder for S mode (optional)" />
                        <ui:Button Grid.Column="2" Content="Browse" Margin="8,0,0,0"
                                   Click="BrowseCatalog_Click" />
                    </Grid>
                </ui:CardControl.Header>
            </ui:CardControl>

            <!-- ═══ Options ═══ -->
            <TextBlock Text="Options" FontWeight="SemiBold" Margin="0,20,0,8" />
            <ui:CardControl>
                <ui:CardControl.Header>
                    <StackPanel Orientation="Horizontal">
                        <CheckBox Content="Quiet Mode (-q)"
                                  IsChecked="{Binding IsQuiet}"
                                  IsEnabled="{Binding IsSuperQuiet, Converter={StaticResource InverseBoolConverter}}"
                                  Margin="0,0,24,0" />
                        <CheckBox Content="Super Quiet Mode (-qq)"
                                  IsChecked="{Binding IsSuperQuiet}" />
                    </StackPanel>
                </ui:CardControl.Header>
            </ui:CardControl>

            <!-- ═══ Action ═══ -->
            <ui:Button Content="Create .intunewin Package"
                       Appearance="Primary"
                       HorizontalAlignment="Stretch"
                       Margin="0,24,0,0"
                       Command="{Binding PackageCommand}"
                       IsEnabled="{Binding IsPackaging, Converter={StaticResource InverseBoolConverter}}" />

            <ProgressBar IsIndeterminate="{Binding IsPackaging}"
                         Visibility="{Binding IsPackaging, Converter={StaticResource BoolToVisibilityConverter}}"
                         Margin="0,8,0,0" />

            <ui:Button Content="Open Output Folder"
                       Appearance="Secondary"
                       HorizontalAlignment="Stretch"
                       Margin="0,8,0,0"
                       Command="{Binding OpenOutputFolderCommand}"
                       Visibility="{Binding ShowOpenOutputFolder, Converter={StaticResource BoolToVisibilityConverter}}" />
        </StackPanel>

        <!-- ═══════════ RIGHT COLUMN ═══════════ -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- ═══ Output Log ═══ -->
            <Grid Grid.Row="0" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Output Log" FontWeight="SemiBold" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <ui:Button Content="Copy" Command="{Binding CopyLogCommand}" Padding="8,4" Margin="0,0,8,0" />
                    <ui:Button Content="Clear" Command="{Binding ClearLogCommand}" Padding="8,4" />
                </StackPanel>
            </Grid>
            <ui:TextBox Grid.Row="1" x:Name="LogTextBox"
                        Text="{Binding LogOutput, Mode=OneWay}"
                        IsReadOnly="True"
                        AcceptsReturn="True"
                        TextWrapping="Wrap"
                        VerticalScrollBarVisibility="Auto"
                        FontFamily="Cascadia Mono, Consolas, Courier New"
                        FontSize="12" />
        </Grid>
    </Grid>

</UserControl>
